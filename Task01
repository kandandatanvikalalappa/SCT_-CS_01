import sys

def caesar_cipher(text: str, shift: int, mode: str) -> str:
    """
    Encrypts or decrypts a text string using the classic Caesar Cipher algorithm.
    Preserves uppercase, lowercase, punctuation, and whitespaces.
    """
    processed_chars = []
    if mode == "decrypt":
        shift = -shift
    shift = shift % 26

    for char in text:
        if char.isupper():
            shifted_char = chr((ord(char) - 65 + shift) % 26 + 65)
            processed_chars.append(shifted_char)
        elif char.islower():
            shifted_char = chr((ord(char) - 97 + shift) % 26 + 97)
            processed_chars.append(shifted_char)
        else:
            processed_chars.append(char)
            
    return "".join(processed_chars)
def main():
    print("=" * 40)
    print("      CYBERSECURITY CAESAR CIPHER TOOL      ")
    print("=" * 40)
    while True:
        mode = input("Select operation (encrypt / decrypt): ").strip().lower()
        if mode in ["encrypt", "decrypt"]:
            break
        print("[-] Error: Invalid operation choice. Type 'encrypt' or 'decrypt'.")
    message = input(f"Enter the message to {mode}: ")
    while True:
        try:
            shift = int(input("Enter key/shift value (integer): ").strip())
            break
        except ValueError:
            print("[-] Error: Key must be a valid structured integer.")
    output_text = caesar_cipher(message, shift, mode)
    print("\n" + "-" * 40)
    print(f"[+] Resulting {mode.capitalize()}ed Text:")
    print(f"--> {output_text}")
    print("-" * 40)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n[-] Operation cancelled by user.")
        sys.exit(0)
